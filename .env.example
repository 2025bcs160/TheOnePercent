# Frontend Environment Variables Example
# Copy this to .env.local and fill in your values

# API Base URL - Change this for production deployment
# For local development: http://localhost:8000
# For production: https://your-backend-api.com
VITE_API_URL=http://localhost:8000

# App Configuration
VITE_APP_NAME=TheOnePercent
VITE_APP_VERSION=1.0.0

# Feature Flags (for development/production toggles)
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_COMMUNITY=true
VITE_ENABLE_BACKTESTING=true