# Backend Server Configuration
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development

# CORS Configuration (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:5174

# MetaTrader 5 Credentials (stored in environment for security)
# NOTE: NEVER commit actual credentials to version control
# Use a secure secrets manager in production
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# Optional: Logging Level
LOG_LEVEL=INFO
